{
  "name": "apex",
  "languageId": "apex",
  "command": [
    "java",
    "-cp",
    "$HOME/.local/apex-lsp/apex-lsp.jar",
    "apex.jorje.lsp.ApexLanguageServerLauncher"
  ],
  "documentSelector": [
    { "language": "apex", "scheme": "file" },
    { "language": "apex-anon", "scheme": "file" }
  ],
  "initializationOptions": {
    "enableEmbeddedSoqlCompletion": true
  },
  "middleware": "$HOME/.config/doom/packages/salesforce-packages/salesforcedx-vscode/packages/salesforcedx-vscode-apex/out/src/embeddedSoql/soqlCompletion.js",
  "settings": {

  }
}
